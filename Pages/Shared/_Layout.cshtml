@using Microsoft.AspNetCore.Http
@{
    var userId = Context.Session.GetString("UserId");
    var userName = Context.Session.GetString("UserName");
    var userRole = Context.Session.GetString("UserRole");
    var userType = Context.Session.GetString("UserType");
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Grand Azure</title>

    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="layout-wrapper">
        <!-- ═══ SIDEBAR ═══ -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <div class="sidebar-brand-icon">
                    <i class="fa-solid fa-hotel"></i>
                </div>
                <span class="sidebar-brand-text">Grand Azure</span>
            </div>

            <ul class="sidebar-nav">
                @if (userId == null)
                {
                    <div class="nav-group-label">Main</div>
                    <li>
                        <a href="/" class="@(Context.Request.Path == "/" ? "active" : "")">
                            <i class="fa-solid fa-house"></i> Home
                        </a>
                    </li>
                    <li>
                        <a href="/Customer/Index" class="@(Context.Request.Path.StartsWithSegments("/Customer/Index") ? "active" : "")">
                            <i class="fa-solid fa-magnifying-glass"></i> Find a Room
                        </a>
                    </li>
                    <div class="sidebar-divider"></div>
                    <li class="px-3 mt-2">
                        <a href="/Account/Login" class="btn btn-primary w-100 justify-content-center" style="color:#fff; text-decoration:none; height:36px;">Sign In</a>
                    </li>
                }
                else
                {
                    <div class="nav-group-label">Main</div>

                    @if (userType == "Customer")
                    {
                        <li>
                            <a href="/Customer/Index" class="@(Context.Request.Path == "/Customer/Index" ? "active" : "")">
                                <i class="fa-solid fa-magnifying-glass"></i> Book a Room
                            </a>
                        </li>
                        <li>
                            <a href="/Customer/MyBookings" class="@(Context.Request.Path == "/Customer/MyBookings" ? "active" : "")">
                                <i class="fa-solid fa-list-check"></i> My Bookings
                            </a>
                        </li>
                    }
                    else if (userType == "Staff")
                    {
                        <li>
                            <a href="/Admin/Index" class="@(Context.Request.Path == "/Admin/Index" ? "active" : "")">
                                <i class="fa-solid fa-chart-line"></i> Dashboard
                            </a>
                        </li>
                        <li>
                            <a href="/Admin/Bookings/Index" class="@(Context.Request.Path.StartsWithSegments("/Admin/Bookings") ? "active" : "")">
                                <i class="fa-solid fa-calendar-days"></i> Bookings
                            </a>
                        </li>

                        @if (userRole == "Admin")
                        {
                            <div class="sidebar-divider"></div>
                            <div class="nav-group-label">Management</div>
                            <li>
                                <a href="/Admin/Rooms/Index" class="@(Context.Request.Path.StartsWithSegments("/Admin/Rooms") ? "active" : "")">
                                    <i class="fa-solid fa-door-open"></i> Rooms
                                </a>
                            </li>
                            <li>
                                <a href="/Admin/RoomCategories/Index" class="@(Context.Request.Path.StartsWithSegments("/Admin/RoomCategories") ? "active" : "")">
                                    <i class="fa-solid fa-tags"></i> Categories
                                </a>
                            </li>
                            <li>
                                <a href="/Admin/Staff/Index" class="@(Context.Request.Path.StartsWithSegments("/Admin/Staff") ? "active" : "")">
                                    <i class="fa-solid fa-user-shield"></i> Staff
                                </a>
                            </li>
                        }
                    }

                    @if (userRole == "Admin" || userRole == "Manager")
                    {
                        <li>
                            <a asp-page="/Admin/Services/Index" class="@(Context.Request.Path.StartsWithSegments("/Admin/Services") ? "active" : "")">
                                <i class="fa-solid fa-concierge-bell"></i> Services
                            </a>
                        </li>
                    }

                    <div class="sidebar-divider"></div>
                    <div class="nav-group-label">Account</div>

                    @if (userType == "Customer")
                    {
                        <li>
                            <a href="/Customer/Profile" class="@(Context.Request.Path.StartsWithSegments("/Customer/Profile") ? "active" : "")">
                                <i class="fa-solid fa-user"></i> My Profile
                            </a>
                        </li>
                    }
                    else if (userType == "Staff")
                    {
                        <li>
                            <a href="/Admin/Profile" class="@(Context.Request.Path.StartsWithSegments("/Admin/Profile") ? "active" : "")">
                                <i class="fa-solid fa-user"></i> My Profile
                            </a>
                        </li>
                    }
                    <li>
                        <a href="/Account/Logout" class="text-danger">
                            <i class="fa-solid fa-right-from-bracket"></i> Logout
                        </a>
                    </li>
                }
            </ul>

            @if (userId != null)
            {
                <div class="sidebar-user-panel">
                    <div class="avatar-initials">
                        @(userName?.Substring(0, 1).ToUpper() ?? "U")
                    </div>
                    <div style="overflow:hidden;">
                        <div class="user-name">@userName</div>
                        <div class="user-role">@userRole</div>
                    </div>
                </div>
            }
        </aside>

        <!-- ═══ SIDEBAR OVERLAY (mobile) ═══ -->
        <div class="sidebar-overlay" id="sidebarOverlay"></div>

        <!-- ═══ MAIN WRAPPER ═══ -->
        <div class="main-wrapper">
            <!-- Top Bar -->
            <header class="topbar">
                <div class="topbar-left">
                    <button class="sidebar-toggle" id="sidebarToggle" type="button" aria-label="Toggle sidebar">
                        <i class="fa-solid fa-bars"></i>
                    </button>
                    <h1 class="topbar-title">@ViewData["Title"]</h1>
                </div>
                <div class="topbar-right">
                    <button class="dark-mode-toggle" id="darkModeToggle" type="button" aria-label="Toggle dark mode">
                        <i class="fa-solid fa-moon"></i>
                    </button>
                </div>
            </header>

            <!-- Main Content -->
            <main class="main-content">
                <!-- Toast Container -->
                <div id="toastContainer" class="toast-container"></div>

                <!-- Global Alerts -->
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success d-flex align-items-center animate-enter" data-auto-dismiss="5000">
                        <i class="fa-solid fa-circle-check me-2"></i>
                        <div>@TempData["SuccessMessage"]</div>
                        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger d-flex align-items-center animate-enter" data-auto-dismiss="5000">
                        <i class="fa-solid fa-circle-exclamation me-2"></i>
                        <div>@TempData["ErrorMessage"]</div>
                        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                    </div>
                }

                @RenderBody()
            </main>
        </div>
    </div>

    @if (TempData["DialogModel"] != null)
    {
        @using HMS.Models.ViewModels
        @using System.Text.Json
        DialogModel? dialogModel = null;
        if (TempData["DialogModel"] is DialogModel dm)
        {
            dialogModel = dm;
        }
        else if (TempData["DialogModel"] is string jsonStr)
        {
            try
            {
                dialogModel = JsonSerializer.Deserialize<DialogModel>(jsonStr);
            }
            catch {}
        }
        else
        {
            try
            {
                var rawJson = JsonSerializer.Serialize(TempData["DialogModel"]);
                dialogModel = JsonSerializer.Deserialize<DialogModel>(rawJson);
            }
            catch {}
        }

        if (dialogModel != null)
        {
            <partial name="_EnterpriseDialog" model="dialogModel" />
        }
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
