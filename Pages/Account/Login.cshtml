@page
@model HMS.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In - HASRIKAHN</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="auth-page">
        <div class="auth-card auth-card-login animate-enter">
            <!-- Branding -->
            <div class="auth-brand">
                <div class="auth-brand-icon">
                    <i class="fa-solid fa-hotel"></i>
                </div>
                <h1 class="auth-brand-name">HASRIKAHN</h1>
                <p class="auth-brand-tagline">Sign in to your account</p>
            </div>

            <!-- Error -->
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger d-flex align-items-center mb-3">
                    <i class="fa-solid fa-circle-xmark me-2"></i> @Model.ErrorMessage
                </div>
            }

            <form method="post" autocomplete="off">
                <!-- Dummy fields to trick browser autofill -->
                <input type="text" style="display:none" autocomplete="off" />
                <input type="password" style="display:none" autocomplete="off" />

                <!-- User Type Toggle -->
                <div class="user-type-toggle">
                    <input type="radio" class="btn-check" name="UserType" id="typeCustomer" value="Customer" @(Model.UserType == "Customer" ? "checked" : "")>
                    <label class="user-type-label" for="typeCustomer">
                        <i class="fa-solid fa-user me-1"></i> Customer
                    </label>
                    <input type="radio" class="btn-check" name="UserType" id="typeStaff" value="Staff" @(Model.UserType == "Staff" ? "checked" : "")>
                    <label class="user-type-label" for="typeStaff">
                        <i class="fa-solid fa-user-tie me-1"></i> Staff
                    </label>
                </div>

                <!-- Username -->
                <div class="mb-3">
                    <label asp-for="Username" class="form-label-enterprise">Username</label>
                    <input asp-for="Username" class="form-control form-control-enterprise" placeholder="Enter username" autocomplete="new-username" required />
                </div>

                <!-- Password -->
                <div class="mb-4">
                    <label asp-for="Password" class="form-label-enterprise">Password</label>
                    <input asp-for="Password" type="password" class="form-control form-control-enterprise" placeholder="Enter password" autocomplete="new-password" required />
                </div>

                <!-- Submit -->
                <button type="submit" class="btn btn-primary w-100 mb-3" style="height:40px;">
                    <i class="fa-solid fa-right-to-bracket me-1"></i> Sign In
                </button>

                <div class="text-center">
                    <span class="text-caption">New here? </span>
                    <a asp-page="/Account/Register" class="text-caption fw-medium" style="color: var(--clr-primary);">Create a customer account</a>
                </div>
            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
</body>
</html>
