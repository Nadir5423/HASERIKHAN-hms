@page
@model HMS.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Register";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register - Grand Azure</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="auth-page">
        <div class="auth-card auth-card-register animate-enter">
            <!-- Branding -->
            <div class="auth-brand">
                <div class="auth-brand-icon">
                    <i class="fa-solid fa-hotel"></i>
                </div>
                <h1 class="auth-brand-name">Grand Azure</h1>
                <p class="auth-brand-tagline">Create your customer account</p>
            </div>

            <!-- Error -->
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger d-flex align-items-center mb-3">
                    <i class="fa-solid fa-circle-xmark me-2"></i> @Model.ErrorMessage
                </div>
            }

            <form method="post" autocomplete="off">
                <!-- Dummy inputs to consume eagar browser auto-fill -->
                <input type="text" style="display:none" autocomplete="off" />
                <input type="password" style="display:none" autocomplete="off" />

                <div class="row">
                    <!-- Name -->
                    <div class="col-md-6 mb-3">
                        <label asp-for="Name" class="form-label-enterprise">Full Name</label>
                        <input asp-for="Name" class="form-control form-control-enterprise" placeholder="Nadir" autocomplete="new-name" required />
                    </div>
                    <!-- Email -->
                    <div class="col-md-6 mb-3">
                        <label asp-for="Email" class="form-label-enterprise">Email Address</label>
                        <input asp-for="Email" type="email" class="form-control form-control-enterprise" placeholder="nadir@example.com" autocomplete="new-email" required />
                    </div>
                </div>

                <div class="row">
                    <!-- Phone -->
                    <div class="col-md-6 mb-3">
                        <label asp-for="Phone" class="form-label-enterprise">Phone Number</label>
                        <input asp-for="Phone" class="form-control form-control-enterprise" placeholder="1234567890" autocomplete="new-phone" required />
                    </div>
                    <!-- Address -->
                    <div class="col-md-6 mb-3">
                        <label asp-for="Address" class="form-label-enterprise">Address (Optional)</label>
                        <input asp-for="Address" class="form-control form-control-enterprise" placeholder="123 Main St" autocomplete="new-address" />
                    </div>
                </div>

                <div class="row">
                    <!-- Username -->
                    <div class="col-md-6 mb-3">
                        <label asp-for="Username" class="form-label-enterprise">Username</label>
                        <input asp-for="Username" class="form-control form-control-enterprise" placeholder="nadir123" autocomplete="new-username" required />
                    </div>
                    <!-- Password -->
                    <div class="col-md-6 mb-4">
                        <label asp-for="Password" class="form-label-enterprise">Password</label>
                        <input asp-for="Password" type="password" class="form-control form-control-enterprise" placeholder="••••••••" autocomplete="new-password" required />
                    </div>
                </div>

                <!-- Submit -->
                <button type="submit" class="btn btn-primary w-100 mb-3" style="height:40px;">
                    <i class="fa-solid fa-user-plus me-1"></i> Register Now
                </button>

                <div class="text-center">
                    <span class="text-caption">Already have an account? </span>
                    <a asp-page="/Account/Login" class="text-caption fw-medium" style="color: var(--clr-primary);">Sign in here</a>
                </div>
            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
</body>
</html>
