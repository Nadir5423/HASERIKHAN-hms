@page "/Admin/Services/Delete"
@using HMS.Models.Entities
@model HMS.Pages.Admin.Services.DeleteModel
@{
    ViewData["Title"] = "Delete Service";
}

<div class="row mb-4 align-items-end">
    <div class="col animate-enter delay-100">
        <h2 class="text-headline mb-0"><i class="fa-solid fa-trash-can me-2" style="color: var(--clr-danger);"></i> Delete Service</h2>
        <p class="text-body text-muted mb-0">Confirm the permanent deletion of this hotel service</p>
    </div>
</div>

<div class="row animate-enter delay-200">
    <div class="col-md-6 mx-auto">
        <div class="card card-enterprise shadow-sm border-danger-subtle">
            <div class="card-body p-4 text-center">
                <div class="mb-4">
                    <i class="fa-solid fa-triangle-exclamation fa-4x text-warning mb-3"></i>
                    <h4 class="text-subhead" style="color: var(--clr-primary-900);">Are you sure you want to delete this service?</h4>
                    <p class="text-muted mt-2">
                        You are about to delete service: <strong style="color: var(--clr-primary-900);">@Model.Service.ServiceName</strong>
                    </p>
                </div>

                <form method="post">
                    <input type="hidden" asp-for="Service.ServiceId" />
                    <div class="d-flex justify-content-between mt-4">
                        <a asp-page="/Admin/Services/Index" class="btn btn-outline-secondary">
                            <i class="fa-solid fa-arrow-left me-2"></i>Cancel
                        </a>
                        <button type="submit" class="btn btn-danger">
                            <i class="fa-solid fa-trash-can me-2"></i>Confirm Delete
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
