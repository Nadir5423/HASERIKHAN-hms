@page "/Admin/Services/Edit"
@using HMS.Models.Entities
@model HMS.Pages.Admin.Services.EditModel
@{
    ViewData["Title"] = "Edit Service";
}

<div class="row mb-4 align-items-end">
    <div class="col animate-enter delay-100">
        <h2 class="text-headline mb-0"><i class="fa-solid fa-pen-to-square me-2" style="color: var(--clr-primary-500);"></i> Edit Service</h2>
        <p class="text-body text-muted mb-0">Modify details of an existing service</p>
    </div>
</div>

<div class="row animate-enter delay-200">
    <div class="col-md-6 mx-auto">
        <div class="card card-enterprise shadow-sm">
            <div class="card-body p-4">
                @if (!ModelState.IsValid)
                {
                    <div class="alert alert-danger mb-4" role="alert">
                        <div asp-validation-summary="All" class="mb-0"></div>
                    </div>
                }

                <form method="post">
                    <input type="hidden" asp-for="Service.ServiceId" />

                    <div class="mb-3">
                        <label asp-for="Service.ServiceName" class="form-label-enterprise">Service Name</label>
                        <input asp-for="Service.ServiceName" class="form-control form-control-enterprise" required />
                        <span asp-validation-for="Service.ServiceName" class="text-danger font-size-sm"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Service.ServiceType" class="form-label-enterprise">Service Type</label>
                        <select asp-for="Service.ServiceType" class="form-control form-control-enterprise form-select" required>
                            <option value="Food">Food</option>
                            <option value="Transport">Transport</option>
                            <option value="Spa">Spa</option>
                            <option value="Laundry">Laundry</option>
                            <option value="Other">Other</option>
                        </select>
                        <span asp-validation-for="Service.ServiceType" class="text-danger font-size-sm"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Service.Description" class="form-label-enterprise">Description</label>
                        <textarea asp-for="Service.Description" class="form-control form-control-enterprise" rows="3"></textarea>
                        <span asp-validation-for="Service.Description" class="text-danger font-size-sm"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Service.Price" class="form-label-enterprise">Price ($)</label>
                        <input asp-for="Service.Price" type="number" step="0.01" class="form-control form-control-enterprise" required />
                        <span asp-validation-for="Service.Price" class="text-danger font-size-sm"></span>
                    </div>

                    <div class="mb-4 form-check">
                        <input asp-for="Service.IsAvailable" class="form-check-input" type="checkbox" />
                        <label asp-for="Service.IsAvailable" class="form-check-label">Available for Selection</label>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <a asp-page="/Admin/Services/Index" class="btn btn-outline-secondary">
                            <i class="fa-solid fa-arrow-left me-2"></i>Cancel
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="fa-solid fa-save me-2"></i>Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
