@page "{id:int}"
@model HMS.Pages.Admin.RoomCategories.DeleteModel
@{
    ViewData["Title"] = "Delete Category";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 text-center">
        <div class="card card-enterprise shadow-sm animate-enter delay-100">
            <div class="card-body p-5">
                <i class="fa-solid fa-triangle-exclamation fa-4x mb-4" style="color: var(--clr-danger);"></i>
                <h3 class="text-headline mb-3">Delete Room Category?</h3>
                <p class="text-body text-muted mb-4">
                    Are you sure you want to delete category <strong style="color: var(--clr-primary-900);">@Model.Category.CategoryName</strong>? 
                    This action cannot be undone and will fail if rooms exist under this category.
                </p>

                <form method="post">
                    <input type="hidden" asp-for="Category.CategoryId" />
                    
                    <div class="d-flex justify-content-center gap-3">
                        <a asp-page="./Index" class="btn btn-outline-secondary px-4"><i class="fa-solid fa-arrow-left me-1"></i> Cancel</a>
                        <button type="submit" class="btn btn-danger px-4"><i class="fa-solid fa-trash-can me-1"></i> Confirm Delete</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

