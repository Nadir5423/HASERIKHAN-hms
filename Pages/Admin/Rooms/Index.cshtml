@page
@model HMS.Pages.Admin.Rooms.IndexModel
@{
    ViewData["Title"] = "Rooms";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="text-display mb-1">Rooms</h1>
        <p class="text-body text-slate mb-0">View and manage hotel rooms and their operational status</p>
    </div>
    <a asp-page="./Create" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Add Room</a>
</div>

<div class="card card-enterprise animate-enter delay-100">
    <div class="card-body p-0">
        @if (Model.Rooms.Count == 0)
        {
            <div class="text-center py-5 text-slate">
                <i class="fa-solid fa-inbox fa-3x mb-3 opacity-25"></i>
                <p class="mb-0">No rooms found. Click 'Add Room' to create one.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table-enterprise">
                    <thead>
                        <tr>
                            <th>Room Number</th>
                            <th>Category</th>
                            <th>Floor</th>
                            <th>Price / Night</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var room in Model.Rooms)
                        {
                            <tr>
                                <td>
                                    <span class="room-number-pill">Room @room.RoomNumber</span>
                                </td>
                                <td class="fw-medium">@room.Category?.CategoryName</td>
                                <td class="text-slate">Floor @(string.IsNullOrEmpty(room.Floor) ? "-" : room.Floor)</td>
                                <td class="fw-medium">$@room.Category?.BasePrice.ToString("N2")</td>
                                <td>
                                    <span class="badge-status @(room.Status.ToLower() switch {
                                        "available" => "badge-available",
                                        "occupied" => "badge-occupied",
                                        "maintenance" => "badge-maintenance",
                                        "reserved" => "badge-reserved",
                                        _ => "badge-pending"
                                    })">
                                        @room.Status
                                    </span>
                                </td>
                                <td class="text-end">
                                    <div class="d-inline-flex gap-2">
                                        <a asp-page="./Edit" asp-route-id="@room.RoomId" class="btn-icon-only btn-edit" title="Edit">
                                            <i class="fa-solid fa-pen-to-square"></i>
                                        </a>
                                        <a asp-page="./Delete" asp-route-id="@room.RoomId" class="btn-icon-only btn-delete" title="Delete">
                                            <i class="fa-solid fa-trash-can"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
