@page
@model HMS.Pages.Admin.EditProfileModel
@{
    ViewData["Title"] = "Edit Profile";
}

<div class="row mb-4 align-items-end">
    <div class="col animate-enter delay-100">
        <h2 class="text-headline mb-0"><i class="fa-solid fa-user-pen me-2" style="color: var(--clr-primary-500);"></i> Edit Profile</h2>
        <p class="text-body text-muted mb-0">Update your personal staff information</p>
    </div>
</div>

<div class="row animate-enter delay-200">
    <div class="col-md-6 mx-auto">
        <div class="card card-enterprise shadow-sm">
            <div class="card-body p-4">
                @if (!ModelState.IsValid)
                {
                    <div class="alert alert-danger mb-4" role="alert">
                        <div asp-validation-summary="All" class="mb-0"></div>
                    </div>
                }

                <form method="post">
                    <!-- Hidden inputs for non-editable fields -->
                    <input type="hidden" asp-for="Staff.StaffId" />

                    <div class="mb-3">
                        <label asp-for="Staff.Name" class="form-label-enterprise">Full Name</label>
                        <input asp-for="Staff.Name" class="form-control form-control-enterprise" required />
                        <span asp-validation-for="Staff.Name" class="text-danger font-size-sm"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Staff.Email" class="form-label-enterprise">Email Address</label>
                        <input asp-for="Staff.Email" type="email" class="form-control form-control-enterprise" required />
                        <span asp-validation-for="Staff.Email" class="text-danger font-size-sm"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Staff.Phone" class="form-label-enterprise">Phone Number</label>
                        <input asp-for="Staff.Phone" class="form-control form-control-enterprise" />
                        <span asp-validation-for="Staff.Phone" class="text-danger font-size-sm"></span>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <a asp-page="./Profile" class="btn btn-outline-secondary">
                            <i class="fa-solid fa-arrow-left me-2"></i>Cancel
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="fa-solid fa-save me-2"></i>Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
