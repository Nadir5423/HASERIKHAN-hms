@page
@model HMS.Pages.Admin.Bookings.IndexModel
@{
    ViewData["Title"] = "Bookings";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="text-display mb-1">Bookings</h1>
        <p class="text-body text-slate mb-0">View, monitor, and manage check-ins, check-outs, and customer reservations</p>
    </div>
</div>

<div class="card card-enterprise animate-enter delay-100">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table-enterprise">
                <thead>
                    <tr>
                        <th>Reference</th>
                        <th>Customer</th>
                        <th>Room</th>
                        <th>Check-In</th>
                        <th>Check-Out</th>
                        <th>Status</th>
                        <th>Total Amount</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Bookings)
                    {
                        <tr>
                            <td class="text-mono">@item.BookingReference</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="avatar-initials avatar-initials-sm">
                                        @(item.Customer?.Name?.Substring(0, 1).ToUpper() ?? "G")
                                    </div>
                                    <div>
                                        <div class="fw-medium">@item.Customer?.Name</div>
                                        <div class="text-caption" style="font-size: 11px;">@item.Customer?.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="room-number-pill">Room @item.Room?.RoomNumber</span>
                            </td>
                            <td class="text-slate">@item.CheckInDate.ToString("dd MMM yyyy")</td>
                            <td class="text-slate">@item.CheckOutDate.ToString("dd MMM yyyy")</td>
                            <td>
                                <span class="badge-status @(item.BookingStatus.ToLower() switch {
                                    "pending" => "badge-pending",
                                    "confirmed" => "badge-confirmed",
                                    "checkedin" => "badge-checkedin",
                                    "checkedout" => "badge-checkedout",
                                    "cancelled" => "badge-cancelled",
                                    _ => "badge-pending"
                                })">
                                    @item.BookingStatus
                                </span>
                            </td>
                            <td class="fw-medium text-primary-color">$@item.TotalAmount.ToString("N2")</td>
                            <td class="text-end">
                                <a asp-page="./Details" asp-route-id="@item.BookingId" class="btn-icon-only btn-view" title="Manage Details">
                                    <i class="fa-solid fa-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Bookings.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5 text-slate">
                                <i class="fa-solid fa-inbox fa-3x mb-3 opacity-25"></i>
                                <p class="mb-0">No bookings found in the system.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
